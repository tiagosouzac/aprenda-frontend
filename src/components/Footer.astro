---
interface FooterLink {
  label: string;
  href: string;
  external?: boolean;
}
interface FooterColumn {
  heading: string;
  links: FooterLink[];
  cols?: number;
}

const columns: FooterColumn[] = [
  {
    heading: "módulos",
    cols: 2,
    links: [
      { label: "Como a web funciona", href: "/how-the-web-works" },
      { label: "HTML", href: "/html" },
      { label: "CSS", href: "/css" },
      { label: "JavaScript", href: "/javascript" },
      { label: "TypeScript", href: "/typescript" },
      { label: "React", href: "/react" },
      { label: "Testes", href: "/testing" },
      { label: "Próximos passos", href: "/next-steps" },
    ],
  },
  {
    heading: "projeto",
    links: [
      { label: "GitHub", href: "https://github.com", external: true },
      { label: "Feedback", href: "https://github.com", external: true },
      { label: "Changelog", href: "https://github.com", external: true },
    ],
  },
];
---

<footer class="relative bg-night text-white/70 overflow-hidden">
  <div class="absolute inset-0 grid-lines opacity-40 [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]"></div>

  <!-- Columns -->
  <div class="relative mx-auto max-w-[1360px] px-6 lg:px-10 pt-20 lg:pt-24 pb-10 border-t border-line-dark">
    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1.8fr_1fr] gap-10 lg:gap-16">
      <div>
        <a href="/" class="flex items-center gap-2.5">
          <span class="relative flex h-7 w-7 items-center justify-center rounded-md bg-white text-night">
            <span class="mono text-[12px] font-medium tracking-tight">af</span>
            <span class="absolute -right-1 -top-1 h-2 w-2 rounded-full bg-[color:var(--color-react)] ring-2 ring-night"></span>
          </span>
          <span class="font-display text-[15px] font-medium tracking-tight text-white">
            aprenda frontend
          </span>
        </a>
        <p class="mt-6 text-[13.5px] leading-[1.7] text-white/55 max-w-[36ch]">
          Um curso introdutório de desenvolvimento frontend, em português.
        </p>
      </div>

      {
        columns.map((col) => (
          <div>
            <h3 class="mono text-[10.5px] tracking-[0.22em] uppercase text-white/40">
              {col.heading}
            </h3>
            <ul
              class:list={[
                "mt-5",
                col.cols === 2
                  ? "grid grid-flow-col grid-rows-4 gap-x-8 gap-y-2.5"
                  : "space-y-2.5",
              ]}
            >
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="inline-flex items-center gap-1.5 text-[13.5px] text-white/75 hover:text-white transition-colors"
                    {...l.external ? { target: "_blank", rel: "noopener" } : {}}
                  >
                    {l.label}
                    {l.external && (
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M7 17L17 7M8 7h9v9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-6 border-t border-line-dark flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="mono text-[11px] tracking-[0.14em] text-white/40">
        © {new Date().getFullYear()} — aprenda frontend
      </div>
      <div class="flex items-center gap-4 text-white/55">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener"
          aria-label="GitHub"
          class="inline-flex items-center gap-2 text-[13px] hover:text-white transition-colors"
        >
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
            <path
              d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.35-1.3-1.71-1.3-1.71-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.21-1.49 3.19-1.18 3.19-1.18.64 1.59.24 2.77.12 3.06.74.8 1.19 1.83 1.19 3.09 0 4.42-2.7 5.39-5.27 5.68.42.36.79 1.07.79 2.16v3.2c0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
            ></path>
          </svg>
          github do projeto
        </a>
      </div>
    </div>
  </div>
</footer>
