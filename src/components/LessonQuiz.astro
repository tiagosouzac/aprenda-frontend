---
export interface QuizQuestion {
  question: string;
  options: string[];
  correct: number;
}

interface Props {
  questions: QuizQuestion[];
  lessonHref: string;
}

const { questions, lessonHref } = Astro.props;
---

<section
  class="quiz-root mt-16 pt-12 border-t border-line"
  aria-label="Checkpoint da aula"
>
  <div class="flex items-center gap-3 mb-10">
    <span class="mono text-[11px] tracking-[0.18em] uppercase text-mute">/ checkpoint</span>
    <span class="h-px w-10 bg-line"></span>
    <span class="eyebrow text-[15px] text-ink/70">verifique seu entendimento</span>
  </div>

  <div data-quiz data-lesson-href={lessonHref}>
    <!-- Active phase: header + steps + nav -->
    <div data-quiz-active>
      <div class="flex items-center justify-between mb-7">
        <span class="mono text-[10.5px] tracking-[0.18em] uppercase text-mute" data-quiz-counter>
          questão 1 de {questions.length}
        </span>
        <div class="flex items-center gap-[5px]" data-quiz-dots>
          {questions.map((_, i) => (
            <span
              data-dot-index={i}
              class:list={[
                "h-[6px] w-[6px] rounded-full border-[1.5px] border-line bg-transparent transition-[background,border-color,transform] duration-200",
                i === 0 && "border-ink scale-[1.35]",
              ]}
            />
          ))}
        </div>
      </div>

      <div data-quiz-steps>
        {questions.map((q, i) => (
          <div data-quiz-step={i} class:list={[i !== 0 && "hidden"]}>
            <p class="text-[16px] leading-[1.55] text-ink font-medium mb-4">{q.question}</p>
            <div class="flex flex-col gap-[0.45rem]" data-quiz-options>
              {q.options.map((opt, oi) => (
                <button
                  type="button"
                  data-quiz-option
                  data-correct={oi === q.correct ? "true" : "false"}
                  class="quiz-opt flex items-center w-full text-left px-4 py-[0.8rem] rounded-[0.625rem] border border-line bg-transparent text-ink/[0.68] text-[14.5px] leading-[1.45] cursor-pointer transition-[border-color,background,color,opacity] duration-150 hover:border-ink/[0.22] hover:bg-ink/[0.025] hover:text-ink"
                >
                  {opt}
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="flex items-center justify-between gap-3 mt-6">
        <button
          type="button"
          data-quiz-prev
          class="inline-flex items-center gap-[0.4rem] h-10 px-4 rounded-lg border border-line bg-transparent text-mute text-[13px] font-medium cursor-pointer hover:border-ink hover:text-ink transition-colors disabled:opacity-[0.22] disabled:cursor-default"
          disabled
        >
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 5l-7 7 7 7" />
          </svg>
          Anterior
        </button>
        <button
          type="button"
          data-quiz-next
          class="inline-flex items-center gap-2 h-10 px-[1.125rem] rounded-lg border border-ink bg-ink text-bone text-[13px] font-medium cursor-pointer hover:opacity-[0.82] disabled:opacity-[0.28] disabled:cursor-not-allowed transition-opacity"
          disabled
        >
          Próxima
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>
        <button
          type="button"
          data-quiz-submit
          class="hidden items-center gap-2 h-10 px-[1.125rem] rounded-lg border border-ink bg-ink text-bone text-[13px] font-medium cursor-pointer hover:opacity-[0.82] disabled:opacity-[0.28] disabled:cursor-not-allowed transition-opacity"
          disabled
        >
          Verificar respostas
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Outcome host: filled by script via templates -->
    <div data-quiz-outcome role="status" aria-live="polite" tabindex="-1" class="outline-none"></div>

    <!-- Success template -->
    <template data-quiz-success-template>
      <div class="quiz-fade flex flex-col items-center text-center pt-10 pb-6">
        <div class="flex items-center justify-center w-[52px] h-[52px] rounded-full border-[1.5px] border-emerald-500 mb-5">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline class="quiz-draw-check" points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <p class="font-display text-[1.5rem] font-medium tracking-[-0.02em] text-ink mb-1" style="font-variation-settings: 'opsz' 96, 'wdth' 100;">
          Aula concluída
        </p>
        <p class="text-[14px] text-mute mb-6" data-success-sub></p>
        <button
          type="button"
          data-quiz-redo
          class="inline-flex items-center gap-[0.45rem] h-[38px] px-4 rounded-lg border border-line bg-transparent text-ink text-[13px] font-medium cursor-pointer hover:border-ink transition-colors"
        >
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
            <path d="M3 3v5h5"/>
          </svg>
          Refazer o quiz
        </button>
      </div>
    </template>

    <!-- Error template -->
    <template data-quiz-error-template>
      <div class="quiz-fade flex flex-col items-center text-center pt-10 pb-6">
        <div class="flex items-center justify-center w-[52px] h-[52px] rounded-full border-[1.5px] border-red-500 mb-5">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line class="quiz-draw-x quiz-draw-x-1" x1="8" y1="8" x2="16" y2="16"/>
            <line class="quiz-draw-x quiz-draw-x-2" x1="16" y1="8" x2="8" y2="16"/>
          </svg>
        </div>
        <p class="font-display text-[1.5rem] font-medium tracking-[-0.02em] text-ink mb-1" style="font-variation-settings: 'opsz' 96, 'wdth' 100;">
          Quase lá.
        </p>
        <p class="text-[14px] text-mute mb-6" data-error-sub></p>
        <div class="flex items-center justify-center gap-2 flex-wrap">
          <button
            type="button"
            data-quiz-toggle-results
            class="inline-flex items-center gap-[0.45rem] h-[38px] px-4 rounded-lg border border-line bg-transparent text-ink text-[13px] font-medium cursor-pointer hover:border-ink transition-colors"
          >
            Ver os resultados
          </button>
          <button
            type="button"
            data-quiz-redo
            class="inline-flex items-center gap-[0.45rem] h-[38px] px-4 rounded-lg border border-line bg-transparent text-ink text-[13px] font-medium cursor-pointer hover:border-ink transition-colors"
          >
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
            </svg>
            Refazer o quiz
          </button>
        </div>
        <div class="quiz-fade-fast w-full text-left border-t border-line pt-7 mt-7 hidden" data-results-list></div>
      </div>
    </template>

    <!-- Result row template -->
    <template data-quiz-result-row-template>
      <div class="mb-8">
        <div class="flex items-start gap-4 mb-[0.875rem]">
          <span class="mono text-[10.5px] tracking-[0.18em] uppercase text-mute pt-[0.3em] shrink-0" data-row-num></span>
          <p class="text-[16px] leading-[1.55] text-ink font-medium m-0" data-row-question></p>
        </div>
        <div class="flex flex-col gap-[0.45rem] pl-[2.25rem]" data-row-options></div>
      </div>
    </template>
  </div>
</section>

<style>
  .quiz-opt.is-selected {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-bone);
  }
  .quiz-opt.is-selected:hover {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-bone);
  }

  .quiz-fade { animation: quiz-in 500ms cubic-bezier(0.22, 1, 0.36, 1) both; }
  .quiz-fade-fast { animation: quiz-in 280ms cubic-bezier(0.22, 1, 0.36, 1) both; }

  .quiz-draw-check {
    stroke-dasharray: 24;
    stroke-dashoffset: 24;
    animation: quiz-draw 500ms 150ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .quiz-draw-x {
    stroke-dasharray: 12;
    stroke-dashoffset: 12;
    animation: quiz-draw 320ms ease-out forwards;
  }
  .quiz-draw-x-1 { animation-delay: 80ms; }
  .quiz-draw-x-2 { animation-delay: 230ms; }

  @keyframes quiz-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes quiz-draw {
    to { stroke-dashoffset: 0; }
  }
</style>

<script>
  type Outcome = "active" | "success" | "error";

  interface OptionState {
    el: HTMLButtonElement;
    isCorrect: boolean;
    text: string;
  }

  interface StepState {
    el: HTMLElement;
    questionText: string;
    options: OptionState[];
    selected: number | null;
  }

  const STORAGE_KEY = "aprenda-progress";

  function shuffleInPlace<T>(arr: T[]): T[] {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  function getCompleted(): Set<string> {
    try {
      const raw = JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "[]");
      return new Set(Array.isArray(raw) ? raw : []);
    } catch {
      return new Set();
    }
  }

  function markComplete(href: string) {
    const s = getCompleted();
    s.add(href);
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(s)));
    } catch {
      // storage unavailable (private mode / quota) — progress just won't persist
    }
    document.dispatchEvent(new CustomEvent("progress-update"));
  }

  document.querySelectorAll<HTMLElement>("[data-quiz]").forEach((root) => {
    const lessonHref = root.dataset.lessonHref!;
    const activePhase = root.querySelector<HTMLElement>("[data-quiz-active]")!;
    const stepsEl = root.querySelector<HTMLElement>("[data-quiz-steps]")!;
    const counterEl = root.querySelector<HTMLElement>("[data-quiz-counter]")!;
    const dotsEl = root.querySelector<HTMLElement>("[data-quiz-dots]")!;
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-quiz-prev]")!;
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-quiz-next]")!;
    const submitBtn = root.querySelector<HTMLButtonElement>("[data-quiz-submit]")!;
    const outcomeEl = root.querySelector<HTMLElement>("[data-quiz-outcome]")!;
    const successTpl = root.querySelector<HTMLTemplateElement>("[data-quiz-success-template]")!;
    const errorTpl = root.querySelector<HTMLTemplateElement>("[data-quiz-error-template]")!;
    const resultRowTpl = root.querySelector<HTMLTemplateElement>("[data-quiz-result-row-template]")!;

    const originalSteps: StepState[] = Array.from(
      stepsEl.querySelectorAll<HTMLElement>("[data-quiz-step]"),
    ).map((stepEl) => {
      const optionEls = Array.from(
        stepEl.querySelectorAll<HTMLButtonElement>("[data-quiz-option]"),
      );
      return {
        el: stepEl,
        questionText: stepEl.querySelector("p")?.textContent?.trim() ?? "",
        options: optionEls.map((el) => ({
          el,
          isCorrect: el.dataset.correct === "true",
          text: el.textContent?.trim() ?? "",
        })),
        selected: null,
      };
    });

    let steps: StepState[] = [];
    let current = 0;

    function reshuffle() {
      steps = shuffleInPlace([...originalSteps]);
      // Reorder DOM steps
      steps.forEach((s) => stepsEl.appendChild(s.el));
      // Reorder DOM options within each step
      steps.forEach((step) => {
        const optionsContainer = step.el.querySelector<HTMLElement>("[data-quiz-options]")!;
        const shuffledOpts = shuffleInPlace([...step.options]);
        step.options = shuffledOpts;
        shuffledOpts.forEach((opt) => optionsContainer.appendChild(opt.el));
      });
    }

    function reset() {
      steps.forEach((step) => {
        step.selected = null;
        step.options.forEach((opt) => {
          opt.el.classList.remove("is-selected");
          opt.el.disabled = false;
          opt.el.style.opacity = "";
          opt.el.style.cursor = "";
          opt.el.style.textDecoration = "";
        });
      });
      current = 0;
      outcomeEl.replaceChildren();
      activePhase.classList.remove("hidden");
      render();
    }

    function render() {
      steps.forEach((step, i) => step.el.classList.toggle("hidden", i !== current));

      counterEl.textContent = `questão ${current + 1} de ${steps.length}`;

      // Update dots — DOM order is stable; we map via index
      Array.from(dotsEl.children).forEach((dot, i) => {
        const el = dot as HTMLElement;
        const done = steps[i]?.selected !== null;
        const active = i === current;
        el.classList.toggle("bg-ink", done);
        el.classList.toggle("border-ink", done || active);
        el.classList.toggle("border-line", !done && !active);
        el.classList.toggle("scale-[1.35]", active);
      });

      const isLast = current === steps.length - 1;
      const answered = steps[current].selected !== null;

      prevBtn.disabled = current === 0;

      if (isLast) {
        nextBtn.classList.add("hidden");
        nextBtn.classList.remove("inline-flex");
        submitBtn.classList.remove("hidden");
        submitBtn.classList.add("inline-flex");
        submitBtn.disabled = !answered;
      } else {
        nextBtn.classList.remove("hidden");
        nextBtn.classList.add("inline-flex");
        submitBtn.classList.add("hidden");
        submitBtn.classList.remove("inline-flex");
        nextBtn.disabled = !answered;
      }
    }

    function selectOption(stepIdx: number, optIdx: number) {
      const step = steps[stepIdx];
      step.selected = optIdx;
      step.options.forEach((opt, i) => {
        opt.el.classList.toggle("is-selected", i === optIdx);
      });
      render();
    }

    function go(delta: number) {
      const target = current + delta;
      if (target < 0 || target >= steps.length) return;
      current = target;
      render();
    }

    function showOutcome(kind: Outcome, focusResult = false) {
      activePhase.classList.add("hidden");
      outcomeEl.replaceChildren();

      if (kind === "success") {
        const node = successTpl.content.cloneNode(true) as DocumentFragment;
        const sub = node.querySelector("[data-success-sub]");
        if (sub) sub.textContent = `${steps.length} de ${steps.length} questões certas.`;
        node.querySelector<HTMLButtonElement>("[data-quiz-redo]")?.addEventListener("click", reset);
        outcomeEl.appendChild(node);
      } else {
        const wrong = steps.filter((s) => s.options[s.selected ?? -1]?.isCorrect !== true).length;
        const node = errorTpl.content.cloneNode(true) as DocumentFragment;
        const sub = node.querySelector("[data-error-sub]");
        if (sub) sub.textContent = `Você errou ${wrong} de ${steps.length} questões.`;

        const list = node.querySelector<HTMLElement>("[data-results-list]")!;
        steps.forEach((step, i) => {
          const row = resultRowTpl.content.cloneNode(true) as DocumentFragment;
          const numEl = row.querySelector("[data-row-num]");
          if (numEl) numEl.textContent = String(i + 1).padStart(2, "0");
          const qEl = row.querySelector("[data-row-question]");
          if (qEl) qEl.textContent = step.questionText;

          const optsContainer = row.querySelector<HTMLElement>("[data-row-options]")!;
          step.options.forEach((opt) => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.disabled = true;
            btn.textContent = opt.text;
            btn.className =
              "flex items-center w-full text-left px-4 py-[0.8rem] rounded-[0.625rem] border text-[14.5px] leading-[1.45]";
            if (opt.isCorrect) {
              btn.className += " border-emerald-500 bg-emerald-500/[0.09] text-emerald-800 cursor-default";
            } else if (step.options.indexOf(opt) === step.selected) {
              btn.className += " border-red-300 bg-red-50 text-red-700 line-through cursor-default";
            } else {
              btn.className += " border-line text-ink/[0.68] opacity-[0.32] cursor-default";
            }
            optsContainer.appendChild(btn);
          });
          list.appendChild(row);
        });

        const toggleBtn = node.querySelector<HTMLButtonElement>("[data-quiz-toggle-results]")!;
        toggleBtn.addEventListener("click", () => {
          const isHidden = list.classList.toggle("hidden");
          toggleBtn.textContent = isHidden ? "Ver os resultados" : "Ocultar resultados";
        });
        node.querySelector<HTMLButtonElement>("[data-quiz-redo]")?.addEventListener("click", reset);
        outcomeEl.appendChild(node);
      }

      if (focusResult) outcomeEl.focus();
    }

    function submit() {
      const allOk = steps.every((s) => s.options[s.selected ?? -1]?.isCorrect === true);
      if (allOk) {
        markComplete(lessonHref);
        showOutcome("success", true);
      } else {
        showOutcome("error", true);
      }
    }

    // Use event delegation so clicks keep working after a reshuffle
    stepsEl.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-quiz-option]");
      if (!btn) return;
      const stepEl = btn.closest<HTMLElement>("[data-quiz-step]");
      if (!stepEl) return;
      const stepIdx = steps.findIndex((s) => s.el === stepEl);
      const optIdx = steps[stepIdx].options.findIndex((o) => o.el === btn);
      if (stepIdx === -1 || optIdx === -1) return;
      selectOption(stepIdx, optIdx);
    });

    prevBtn.addEventListener("click", () => go(-1));
    nextBtn.addEventListener("click", () => go(1));
    submitBtn.addEventListener("click", submit);

    // Entry point
    if (getCompleted().has(lessonHref)) {
      reshuffle();
      showOutcome("success");
    } else {
      reshuffle();
      render();
    }
  });
</script>
