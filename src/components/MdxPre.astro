---
const props = Astro.props as Record<string, string | undefined>;
const lang = props["data-language"] ?? "";
const caption = props["data-title"];
---


<figure class="code-block-figure my-8 not-prose">
  <div class="rounded-xl overflow-hidden bg-night ring-1 ring-line-dark shadow-[0_10px_30px_rgba(0,0,0,0.08)]">
    <div class="flex items-center justify-between px-4 py-2.5 bg-white/[0.03] border-b border-white/10">
      <span class="mono text-[10.5px] tracking-[0.18em] uppercase text-white/55">{lang}</span>
      <button
        class="copy-btn flex items-center gap-1.5 mono text-[10.5px] text-white/40 hover:text-white/80 transition-colors cursor-pointer select-none"
        aria-label="Copiar código"
      >
        <svg class="copy-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <svg class="check-icon hidden" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span class="copy-label">copiar</span>
      </button>
    </div>
    <div class="code-wrap px-5 py-4 overflow-x-auto">
      <pre><slot /></pre>
    </div>
  </div>
  {
    caption && (
      <figcaption class="mt-3 text-[13.5px] leading-[1.55] text-mute italic">
        {caption}
      </figcaption>
    )
  }
</figure>

<script>
  document.querySelectorAll<HTMLElement>(".code-block-figure").forEach((fig) => {
    const btn = fig.querySelector<HTMLButtonElement>(".copy-btn");
    const pre = fig.querySelector("pre");
    const copyIcon = btn?.querySelector<SVGElement>(".copy-icon");
    const checkIcon = btn?.querySelector<SVGElement>(".check-icon");
    const label = btn?.querySelector<HTMLSpanElement>(".copy-label");

    btn?.addEventListener("click", () => {
      const text = pre?.textContent?.trim() ?? "";
      navigator.clipboard.writeText(text).then(() => {
        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        if (label) label.textContent = "copiado!";
        setTimeout(() => {
          copyIcon?.classList.remove("hidden");
          checkIcon?.classList.add("hidden");
          if (label) label.textContent = "copiar";
        }, 2000);
      });
    });
  });
</script>
