  <!-- Sidebar active styles -->
  <style is:global>
    #moduleSidebar a.is-active .sidebar-dot {
      background: var(--dot-color);
      box-shadow: 0 0 18px color-mix(in srgb, var(--dot-color) 60%, transparent);
    }
    #moduleSidebar a.is-active .sidebar-label {
      color: #ffffff;
    }
    #moduleSidebar a:hover .sidebar-label {
      color: rgba(255, 255, 255, 0.85);
    }
  </style>

  <script>
    const blocks = document.querySelectorAll<HTMLElement>("[data-module-id]");
    const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>(
      "#moduleSidebar a[data-sidebar-target]"
    );
    const progressBar = document.getElementById("moduleProgress");
    const total = blocks.length;

    const revealIO = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            revealIO.unobserve(e.target);
          }
        }
      },
      { rootMargin: "0px 0px -8% 0px", threshold: 0.12 }
    );
    blocks.forEach((b) => revealIO.observe(b));

    const setActive = (id: string) => {
      let activeIndex = -1;
      sidebarLinks.forEach((link, i) => {
        const match = link.dataset.sidebarTarget === id;
        link.classList.toggle("is-active", match);
        if (match) activeIndex = i;
      });
      if (progressBar && activeIndex >= 0) {
        const pct = ((activeIndex + 1) / total) * 100;
        (progressBar as HTMLElement).style.width = `${pct}%`;
      }
    };

    const updateActive = () => {
      const anchor = window.innerHeight * 0.35;
      let activeId: string | null = null;
      blocks.forEach((b) => {
        const top = b.getBoundingClientRect().top;
        if (top <= anchor) {
          activeId = b.dataset.moduleId ?? activeId;
        }
      });
      if (!activeId && blocks.length) {
        const firstRect = blocks[0].getBoundingClientRect();
        if (firstRect.top < window.innerHeight * 0.9) {
          activeId = blocks[0].dataset.moduleId ?? null;
        }
      }
      if (activeId) setActive(activeId);
    };

    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateActive();
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", updateActive);
    updateActive();
  </script>
</section>
