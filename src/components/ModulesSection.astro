---
import { modules } from "../data/modules";
---

<section id="modulos" class="relative bg-night text-bone">
  <!-- Intro band -->
  <div class="relative border-b border-line-dark">
    <div class="absolute inset-0 grid-lines opacity-60 [mask-image:linear-gradient(to_bottom,black,transparent)]"></div>
    <div class="relative mx-auto max-w-[1360px] px-6 lg:px-10 pt-28 pb-20 lg:pt-36 lg:pb-28">
      <div class="flex items-center gap-3 mb-8">
        <span class="mono text-[11px] tracking-[0.18em] uppercase text-white/50">/ índice</span>
        <span class="h-px w-10 bg-white/20"></span>
        <span class="eyebrow text-white/70 text-[15px]">do navegador ao React</span>
      </div>
      <h2 class="font-display max-w-[20ch] text-[clamp(2.25rem,5.6vw,4.75rem)] leading-[0.98] font-medium tracking-[-0.035em]">
        Um módulo de cada vez.
        <span class="font-serif italic font-normal text-white/60" style="font-family: var(--font-serif);">
          na ordem que faz sentido.
        </span>
      </h2>
      <p class="mt-8 max-w-[58ch] text-[16.5px] leading-[1.6] text-white/60">
        Cada módulo assume apenas o que veio antes.
        Nada de &ldquo;você vai ver isso depois&rdquo; no meio de uma explicação —
        se aparece, é porque já foi construído.
      </p>
    </div>
  </div>

  <!-- Modules grid -->
  <div class="mx-auto max-w-[1360px] px-6 lg:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-x-14">
      <!-- Sticky sidebar -->
      <aside class="hidden lg:block">
        <nav
          id="moduleSidebar"
          class="sticky top-[96px] pt-10 pb-20 self-start"
        >
          <span class="mono text-[10.5px] tracking-[0.2em] uppercase text-white/35 pl-4">índice</span>
          <ul class="mt-6 space-y-0.5" role="list">
            {
              modules.map((m) => (
                <li>
                  <a
                    href={`#m-${m.slug}`}
                    data-sidebar-target={m.slug}
                    class="group relative flex items-center gap-3 pl-4 pr-3 py-2 rounded-md transition-colors"
                  >
                    <span
                      class="sidebar-dot absolute left-0 top-1/2 -translate-y-1/2 h-4 w-[3px] rounded-r-full bg-white/0 transition-all duration-500"
                      style={`--dot-color:${m.color}`}
                    />
                    <span class="mono text-[10.5px] text-white/35 group-[.is-active]:text-white/70 transition-colors">
                      {m.number}
                    </span>
                    <span class="sidebar-label text-[13.5px] text-white/45 transition-colors">
                      {m.label}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>

          <div class="mt-10 pl-4 pr-3 text-white/35 mono text-[10.5px] leading-[1.6]">
            <span class="block">progresso</span>
            <div class="mt-2 h-[3px] w-full rounded-full bg-white/10 overflow-hidden">
              <div id="moduleProgress" class="h-full bg-white/70 transition-[width] duration-500" style="width:0%"></div>
            </div>
          </div>
        </nav>
      </aside>

      <!-- Module content -->
      <div class="py-10 lg:py-16 space-y-10 lg:space-y-16">
        {
          modules.map((m) => (
            <article
              id={`m-${m.slug}`}
              data-module-id={m.slug}
              class="module-block relative rounded-2xl overflow-hidden border border-line-dark bg-night-2"
            >
              <div class="grid grid-cols-1 md:grid-cols-[1fr_1.05fr]">
                {/* Left: text */}
                <div class="relative p-8 lg:p-12 flex flex-col">
                  <div class="flex items-center gap-3">
                    <span
                      class="h-1.5 w-1.5 rounded-full"
                      style={`background:${m.color}`}
                    />
                    <span class="mono text-[11px] tracking-[0.18em] uppercase text-white/50">
                      {m.number} · {m.label}
                    </span>
                  </div>

                  <h3 class="font-display mt-6 text-[28px] lg:text-[38px] leading-[1.04] font-medium tracking-[-0.025em] text-white max-w-[16ch]">
                    {m.card.title}
                  </h3>

                  <p class="mt-5 text-[15.5px] lg:text-[16px] leading-[1.62] text-white/65 max-w-[42ch]">
                    {m.card.description}
                  </p>

                  <div class="mt-auto pt-10">
                    <a
                      href={`/${m.slug}`}
                      class="group inline-flex items-center gap-2 text-[14px] text-white/90 hover:text-white"
                    >
                      <span class="relative">
                        Ver módulo
                        <span
                          class="absolute left-0 -bottom-0.5 h-px w-full origin-left scale-x-100 transition-transform duration-500 group-hover:scale-x-0"
                          style={`background:${m.color}`}
                        />
                        <span
                          class="absolute left-0 -bottom-0.5 h-px w-full origin-right scale-x-0 transition-transform duration-500 group-hover:scale-x-100 bg-white/70"
                        />
                      </span>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="transition-transform group-hover:translate-x-1">
                        <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </div>
                </div>

                {/* Right: visual */}
                <div
                  class="relative min-h-[320px] md:min-h-[420px] overflow-hidden"
                  style={`background:${m.card.visualBg};color:${m.card.visualInk}`}
                >
                  <div class="absolute inset-0 grid-lines opacity-40"></div>
                  <div class="noise"></div>

                  {m.slug === "introducao" && (
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                      <div
                        class="relative w-full max-w-[340px] rounded-lg overflow-hidden ring-1 ring-white/10 shadow-[0_24px_64px_rgba(0,0,0,0.55)]"
                        style="background: rgba(12,6,1,0.84); animation: intro-window 6s ease-in-out infinite;"
                      >
                        {/* Title bar */}
                        <div class="flex items-center gap-1.5 px-3 py-2.5 border-b border-white/10">
                          <span class="h-2 w-2 rounded-full bg-white/25"></span>
                          <span class="h-2 w-2 rounded-full bg-white/18"></span>
                          <span class="h-2 w-2 rounded-full bg-white/12"></span>
                          <span class="ml-auto mono text-[10px] text-white/28">script.js</span>
                        </div>

                        {/* Code area */}
                        <div class="px-4 py-5 mono text-[13px] leading-[2]">
                          {/* Line 1: console.log("Olá, mundo!"); */}
                          <div class="flex items-baseline gap-3">
                            <span class="text-white/22 select-none w-3 text-right shrink-0 text-[11px]">1</span>
                            <div
                              class="overflow-hidden whitespace-nowrap"
                              style="width: 0ch; animation: intro-type 6s linear infinite;"
                            >
                              <span style="color: #fbbf24;">console</span>
                              <span class="text-white/55">.log(</span>
                              <span style="color: #86efac;">&quot;Olá, mundo!&quot;</span>
                              <span class="text-white/55">);</span>
                            </div>
                            <span
                              class="w-[2px] h-[0.9em] self-center shrink-0 rounded-sm"
                              style="background: #fbbf24; animation: intro-cursor 6s ease-in-out infinite;"
                            ></span>
                          </div>

                          {/* Line 2: output */}
                          <div
                            class="flex items-baseline gap-3"
                            style="animation: intro-output 6s ease-in-out infinite;"
                          >
                            <span class="text-white/22 select-none w-3 text-right shrink-0 text-[11px]">2</span>
                            <span class="text-white/32">{"// → "}</span>
                            <span style="color: #fde68a; letter-spacing: 0.01em;">Olá, mundo!</span>
                          </div>
                        </div>
                      </div>

                      <div class="absolute top-5 left-5 mono text-[10.5px] tracking-[0.18em] uppercase text-white/45">
                        hello world
                      </div>
                      <div class="absolute bottom-5 right-5 mono text-[10.5px] tracking-[0.18em] uppercase text-white/35">
                        módulo 00
                      </div>
                    </div>
                  )}

                  {m.slug === "how-the-web-works" && (
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                      <div class="relative w-full max-w-[440px] h-52">
                        {/* Client side: label above + browser + request label below */}
                        <div class="absolute left-0 top-1/2 -translate-y-1/2 flex flex-col items-center gap-2.5">
                          <span class="mono text-[10px] tracking-[0.18em] uppercase text-white/60">cliente</span>
                          <div class="w-24 rounded-md bg-black/35 backdrop-blur ring-1 ring-white/20 overflow-hidden"
                               style="animation: web-browser-pulse 5s ease-in-out infinite;">
                            <div class="flex items-center gap-1 px-2 py-1.5 bg-black/30">
                              <span class="h-1.5 w-1.5 rounded-full bg-white/40"></span>
                              <span class="h-1.5 w-1.5 rounded-full bg-white/30"></span>
                              <span class="h-1.5 w-1.5 rounded-full bg-white/20"></span>
                            </div>
                            <div class="px-2 py-1.5">
                              <div class="h-1 w-full rounded bg-white/30"></div>
                            </div>
                            <div class="px-2 pb-2 space-y-1">
                              <div class="h-1 w-3/4 rounded bg-white/15"></div>
                              <div class="h-1 w-1/2 rounded bg-white/15"></div>
                            </div>
                          </div>
                          <span class="mono text-[10px] tracking-[0.18em] uppercase text-white/45">request</span>
                        </div>

                        {/* Dashed connection */}
                        <div class="absolute left-[28%] right-[28%] top-1/2 -translate-y-1/2 h-px border-t border-dashed border-white/30"></div>

                        {/* Server side: label above + server + response label below */}
                        <div class="absolute right-0 top-1/2 -translate-y-1/2 flex flex-col items-center gap-2.5">
                          <span class="mono text-[10px] tracking-[0.18em] uppercase text-white/60">servidor</span>
                          <div class="w-20 rounded-md bg-black/45 backdrop-blur ring-1 ring-white/25 p-2 space-y-1.5"
                               style="animation: web-server-pulse 5s ease-in-out infinite;">
                            <div class="h-3 rounded-sm bg-white/15 flex items-center px-1.5">
                              <span class="h-1 w-1 rounded-full bg-emerald-400"></span>
                            </div>
                            <div class="h-3 rounded-sm bg-white/15 flex items-center px-1.5">
                              <span class="h-1 w-1 rounded-full bg-emerald-400"></span>
                            </div>
                            <div class="h-3 rounded-sm bg-white/15 flex items-center px-1.5">
                              <span class="h-1 w-1 rounded-full bg-emerald-400"></span>
                            </div>
                          </div>
                          <span class="mono text-[10px] tracking-[0.18em] uppercase text-white/45">response</span>
                        </div>

                        {/* Request packet (travels left → right) */}
                        <div class="absolute top-1/2 -translate-x-1/2 -translate-y-1/2 rounded bg-white text-[#1a2550] px-2 py-0.5 mono text-[9.5px] font-medium tracking-wider shadow-[0_4px_12px_rgba(0,0,0,0.35)]"
                             style="left: 30%; animation: web-out 5s ease-in-out infinite;">
                          GET
                        </div>

                        {/* Response packet (travels right → left) */}
                        <div class="absolute top-1/2 -translate-x-1/2 -translate-y-1/2 rounded bg-emerald-400 text-emerald-950 px-2 py-0.5 mono text-[9.5px] font-medium tracking-wider shadow-[0_4px_12px_rgba(0,0,0,0.35)]"
                             style="left: 70%; animation: web-in 5s ease-in-out infinite;">
                          200
                        </div>
                      </div>
                    </div>
                  )}

                  {m.slug === "html" && (
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                      <div class="relative w-full max-w-[260px] aspect-[4/5] rounded-lg bg-white/5 ring-1 ring-white/10 p-3 flex flex-col gap-2.5 max-md:max-w-[220px]">
                        <div class="h-5 rounded bg-white/35 opacity-0 flex items-center px-2 gap-1.5"
                             style="animation: html-block 6s ease-in-out infinite;">
                          <span class="mono text-[9px] text-white/90 tracking-tight">&lt;header&gt;</span>
                          <span class="ml-auto h-1 w-2 rounded-full bg-white/40"></span>
                          <span class="h-1 w-2 rounded-full bg-white/40"></span>
                          <span class="h-1 w-2 rounded-full bg-white/40"></span>
                        </div>
                        <div class="h-16 rounded bg-white/40 opacity-0 p-2.5 flex flex-col justify-center gap-1.5"
                             style="animation: html-block 6s ease-in-out infinite 0.4s;">
                          <span class="mono text-[9px] text-white/85 tracking-tight">&lt;main&gt;</span>
                          <span class="h-2 w-3/4 rounded bg-white/65"></span>
                          <span class="h-1 w-1/2 rounded bg-white/45"></span>
                        </div>
                        <div class="flex-1 grid grid-cols-2 gap-2.5">
                          <div class="rounded bg-white/30 opacity-0 p-2 flex flex-col gap-1"
                               style="animation: html-block 6s ease-in-out infinite 0.8s;">
                            <span class="mono text-[9px] text-white/80 tracking-tight">&lt;section&gt;</span>
                            <span class="h-1 w-full rounded bg-white/55"></span>
                            <span class="h-1 w-3/4 rounded bg-white/45"></span>
                          </div>
                          <div class="rounded bg-white/30 opacity-0 p-2 flex flex-col gap-1"
                               style="animation: html-block 6s ease-in-out infinite 1s;">
                            <span class="mono text-[9px] text-white/80 tracking-tight">&lt;section&gt;</span>
                            <span class="h-1 w-full rounded bg-white/55"></span>
                            <span class="h-1 w-2/3 rounded bg-white/45"></span>
                          </div>
                        </div>
                        <div class="h-4 rounded bg-white/25 opacity-0 flex items-center px-2"
                             style="animation: html-block 6s ease-in-out infinite 1.4s;">
                          <span class="mono text-[9px] text-white/80 tracking-tight">&lt;footer&gt;</span>
                        </div>
                      </div>
                    </div>
                  )}

                  {m.slug === "css" && (
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                      <div class="relative w-full max-w-[260px] aspect-[4/5] rounded-lg bg-white/5 ring-1 ring-white/10 p-3 flex flex-col gap-2.5 max-md:max-w-[220px]">
                        <div class="h-5 flex items-center px-2 gap-1.5"
                             style="--css-fill: rgba(236, 72, 153, 0.95); animation: css-style 6s ease-in-out infinite;">
                          <span class="h-1 w-5 rounded-full bg-white/70"></span>
                          <span class="ml-auto h-1 w-2 rounded-full bg-white/55"></span>
                          <span class="h-1 w-2 rounded-full bg-white/55"></span>
                          <span class="h-1 w-2 rounded-full bg-white/55"></span>
                        </div>
                        <div class="h-16 p-3 flex flex-col justify-center gap-1.5"
                             style="--css-fill: rgba(255, 255, 255, 0.95); animation: css-style 6s ease-in-out infinite 0.3s;">
                          <span class="h-2 w-3/4 rounded bg-blue-700/70"></span>
                          <span class="h-1 w-1/2 rounded bg-blue-700/45"></span>
                        </div>
                        <div class="flex-1 grid grid-cols-2 gap-2.5">
                          <div class="p-2 flex flex-col gap-1"
                               style="--css-fill: rgba(96, 165, 250, 0.85); animation: css-style 6s ease-in-out infinite 0.6s;">
                            <span class="h-1 w-full rounded bg-white/75"></span>
                            <span class="h-1 w-3/4 rounded bg-white/60"></span>
                            <span class="h-1 w-2/3 rounded bg-white/60"></span>
                          </div>
                          <div class="p-2 flex flex-col gap-1"
                               style="--css-fill: rgba(244, 114, 182, 0.85); animation: css-style 6s ease-in-out infinite 0.85s;">
                            <span class="h-1 w-full rounded bg-white/75"></span>
                            <span class="h-1 w-2/3 rounded bg-white/60"></span>
                            <span class="h-1 w-3/4 rounded bg-white/60"></span>
                          </div>
                        </div>
                        <div class="h-4"
                             style="--css-fill: rgba(96, 165, 250, 0.7); animation: css-style 6s ease-in-out infinite 1.1s;"></div>
                      </div>

                      <pre class="absolute left-4 top-8 -rotate-2 rounded-md bg-black/35 backdrop-blur px-2.5 py-1 mono text-[10.5px] text-white/90 ring-1 ring-white/15 whitespace-nowrap">
                        <p>{".hero {"}</p>
                        <p class="pl-3">{"color: blue;"}</p>
                        <p class="pl-3">{"background: white;"}</p>
                        <p>{"}"}</p>
                      </pre>
                      <div class="absolute right-4 bottom-8 rotate-2 rounded-md bg-black/35 backdrop-blur px-2.5 py-1 mono text-[10.5px] text-white/90 ring-1 ring-white/15 whitespace-nowrap">
                        <p>display: grid</p>
                        <p>grid-template-columns: 1fr 1fr;</p>
                        <p>gap: 1rem;</p>
                      </div>
                    </div>
                  )}

                  {m.slug === "javascript" && (
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                      <div class="relative w-full max-w-[300px] aspect-[5/4] rounded-lg bg-[#1a1700]/45 ring-1 ring-white/10 shadow-[0_20px_60px_rgba(0,0,0,0.3)] flex flex-col items-center justify-center gap-5 p-6">
                        <div class="flex flex-col items-center gap-1.5">
                          <div class="h-1.5 w-32 rounded bg-white/25"></div>
                          <div class="h-1 w-24 rounded bg-white/15"></div>
                        </div>

                        <div class="relative">
                          <button class="rounded-md bg-white text-[#1a1700] px-5 py-2.5 text-[12.5px] font-semibold mono ring-1 ring-white/30 origin-center"
                                  style="animation: js-btn-press 5s ease-in-out infinite;">
                            clicar
                          </button>
                          <div class="absolute pointer-events-none"
                               style="top: 55%; left: 55%;">
                            <div style="animation: js-cursor 5s ease-in-out infinite;">
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="white" class="drop-shadow-[0_2px_3px_rgba(0,0,0,0.5)]" aria-hidden="true">
                                <path d="M5 3l5 14 2.5-5.5L18 9z" stroke="black" stroke-width="1.4" stroke-linejoin="round"/>
                              </svg>
                            </div>
                          </div>
                        </div>

                        <div class="absolute left-1/2 -translate-x-1/2 top-[18%] z-10 pointer-events-none">
                          <div class="rounded-lg bg-[#f0db4f] text-[#1a1700] px-4 py-2.5 ring-2 ring-white/40 shadow-[0_18px_36px_rgba(0,0,0,0.45)] origin-top opacity-0"
                               style="animation: js-popup 5s ease-in-out infinite;">
                            <div class="text-[13px] font-bold whitespace-nowrap">Olá, mundo</div>
                            <div class="mono text-[10px] mt-0.5 text-[#1a1700]/65">onClick</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  )}

                  {m.slug === "typescript" && (
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                      <div class="relative w-full max-w-[360px] rounded-lg bg-[#0b1b3d] p-5 ring-1 ring-white/10 shadow-[0_20px_60px_rgba(0,0,0,0.35)]">
                        <div class="mono text-[12.5px] leading-[1.9] text-white/90">
                          <div>
                            <span class="text-[#8ab4ff]">function</span>
                            <span class="text-white"> soma</span>(
                          </div>
                          <div class="pl-4">
                            <span class="text-white/90">a</span><span
                              class="inline-block text-[#8ab4ff]"
                              style="animation: ts-type-a 8s ease-in-out infinite;">: number</span>,
                          </div>
                          <div class="pl-4">
                            <span class="text-white/90">b</span><span
                              class="inline-block text-[#8ab4ff]"
                              style="animation: ts-type-b 8s ease-in-out infinite;">: number</span>
                          </div>
                          <div>
                            )<span
                              class="inline-block text-[#8ab4ff]"
                              style="animation: ts-type-r 8s ease-in-out infinite;">: number</span>
                            <span class="text-white/70"> {'{'}</span>
                          </div>
                          <div class="pl-4">
                            <span class="text-[#ff9cc2]">return</span>
                            <span class="text-white/90"> a + b</span>;
                          </div>
                          <div class="text-white/70">{'}'}</div>

                          <div class="mt-3 h-6 relative">
                            <div class="absolute inset-0 flex items-center"
                                 style="animation: ts-bad 8s ease-in-out infinite;">
                              <span class="text-white">soma(1, </span>
                              <span class="relative text-[#ffd86b]">
                                <span class="relative z-10">"2"</span>
                                <span class="absolute -bottom-0.5 left-0 right-0 h-0.5 origin-left"
                                      style="background: repeating-linear-gradient(135deg, #ef4444 0 2px, transparent 2px 4px); animation: ts-squiggly 8s ease-in-out infinite;"></span>
                              </span>
                              <span class="text-white">)</span>
                            </div>
                            <div class="absolute inset-0 flex items-center gap-2"
                                 style="animation: ts-good 8s ease-in-out infinite;">
                              <span class="text-white">soma(1, </span>
                              <span class="text-[#ffb86b]">2<span class="text-white">)</span></span>
                              <span class="ml-auto inline-flex h-4 w-4 items-center justify-center rounded-full bg-emerald-400 text-emerald-950"
                                    style="animation: ts-check-in 8s ease-in-out infinite;">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                  <path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                              </span>
                            </div>
                          </div>
                        </div>

                        <div class="absolute left-12 bottom-3 translate-y-full rounded-md bg-red-500/95 text-white px-2.5 py-1.5 mono text-[10px] ring-1 ring-red-400/50 shadow-[0_8px_20px_rgba(220,38,38,0.35)]"
                             style="animation: ts-tooltip 8s ease-in-out infinite;">
                          Type <span class="font-semibold">'string'</span> not assignable to <span class="font-semibold">'number'</span>
                        </div>
                      </div>
                    </div>
                  )}

                  {m.slug === "react" && (
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                      <div class="relative w-full max-w-[300px] aspect-[5/4] rounded-lg bg-black/25 ring-1 ring-white/15 shadow-[0_20px_60px_rgba(0,0,0,0.3)] flex flex-col items-center justify-center gap-6 p-6">
                        <div class="mono text-[10.5px] tracking-[0.18em] uppercase text-white/45">
                          useState
                        </div>

                        <div class="relative h-20 w-20 rounded-full flex items-center justify-center"
                             style="animation: react-flash 6s ease-in-out infinite;">
                          <span class="absolute inset-0 flex items-center justify-center font-display text-[56px] leading-none font-medium text-white tabular-nums"
                                style="animation: react-num-0 6s ease-in-out infinite;">
                            0
                          </span>
                          <span class="absolute inset-0 flex items-center justify-center font-display text-[56px] leading-none font-medium text-white tabular-nums"
                                style="animation: react-num-1 6s ease-in-out infinite;">
                            1
                          </span>
