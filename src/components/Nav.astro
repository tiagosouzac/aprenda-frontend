---
const modules = [
  { label: "Web", href: "/how-the-web-works" },
  { label: "HTML", href: "/html" },
  { label: "CSS", href: "/css" },
  { label: "JavaScript", href: "/javascript" },
  { label: "TypeScript", href: "/typescript" },
  { label: "React", href: "/react" },
  { label: "Testes", href: "/testing" },
  { label: "Próximos passos", href: "/next-steps" },
];
---

<header
  class="sticky top-0 z-50 bg-canvas/85 backdrop-blur-md border-b border-line"
>
  <div class="mx-auto max-w-[1360px] px-6 lg:px-10 h-[66px] flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group">
      <span class="relative flex h-7 w-7 items-center justify-center rounded-md bg-ink text-canvas">
        <span class="mono text-[12px] font-medium tracking-tight">af</span>
        <span class="absolute -right-1 -top-1 h-2 w-2 rounded-full bg-[color:var(--color-react)] ring-2 ring-canvas"></span>
      </span>
      <span class="font-display text-[15px] font-medium tracking-tight">
        aprenda frontend
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      {
        modules.map((m) => (
          <a
            href={m.href}
            class="px-3 py-1.5 text-[13.5px] text-ink/70 hover:text-ink transition-colors rounded-md hover:bg-ink/5"
          >
            {m.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com"
        aria-label="GitHub do projeto"
        class="hidden sm:flex h-9 w-9 items-center justify-center rounded-md text-ink/60 hover:text-ink hover:bg-ink/5 transition-colors"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.35-1.3-1.71-1.3-1.71-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.21-1.49 3.19-1.18 3.19-1.18.64 1.59.24 2.77.12 3.06.74.8 1.19 1.83 1.19 3.09 0 4.42-2.7 5.39-5.27 5.68.42.36.79 1.07.79 2.16v3.2c0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
          ></path>
        </svg>
      </a>
      <a
        href="#modulos"
        class="inline-flex items-center gap-1.5 h-9 px-3.5 rounded-md border border-line text-[13px] font-medium text-ink/80 hover:border-ink hover:text-ink transition-colors"
      >
        módulos
        <span class="mono text-[11px] text-mute">·8</span>
      </a>
    </div>
  </div>
</header>
