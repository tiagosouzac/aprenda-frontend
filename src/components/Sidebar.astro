---
import { course } from "../data/course";

interface Props {
  currentHref: string;
}

const { currentHref } = Astro.props;
---

<nav class="sticky top-[90px] pt-6 pb-20 text-[14px]">
  <div class="mono text-[10.5px] tracking-[0.2em] uppercase text-mute mb-6">
    índice do curso
  </div>

  <ul class="space-y-3.5" role="list">
    {
      course.map((m) => {
        const isCurrentModule = m.lessons.some((l) => l.href === currentHref);
        const hasMultipleLessons = m.lessons.length > 1;
        return (
          <li>
            <a
              href={m.rootHref}
              data-lesson-href={m.lessons.length === 1 ? m.rootHref : undefined}
              class:list={[
                "flex items-center gap-2.5 py-0.5 transition-colors",
                isCurrentModule ? "text-ink" : "text-ink/65 hover:text-ink",
              ]}
            >
              <span
                class="inline-block h-1.5 w-1.5 rounded-full shrink-0"
                style={`background:${m.color}`}
              />
              <span class="mono text-[10.5px] tracking-[0.18em] uppercase text-mute shrink-0">
                {m.number}
              </span>
              <span class:list={["text-[13.5px] tracking-tight flex-1", isCurrentModule && "font-medium"]}>
                {m.name}
              </span>
              <span class="progress-check opacity-0 transition-opacity" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
            </a>

            {isCurrentModule && hasMultipleLessons && (
              <ul class="mt-2 ml-[7px] pl-0 border-l border-line space-y-0.5" role="list">
                {m.lessons.map((lesson) => {
                  const isCurrentLesson = lesson.href === currentHref;
                  return (
                    <li class="relative">
                      <a
                        href={lesson.href}
                        data-lesson-href={lesson.href}
                        class:list={[
                          "flex items-center pl-4 py-1 text-[13px] leading-[1.4] transition-colors",
                          isCurrentLesson
                            ? "text-ink font-medium"
                            : "text-mute hover:text-ink",
                        ]}
                      >
                        {isCurrentLesson && (
                          <span
                            class="absolute left-[-1px] top-[7px] bottom-[7px] w-[2px]"
                            style={`background:${m.color}`}
                          />
                        )}
                        <span class="flex-1">{lesson.title}</span>
                        <span class="progress-check opacity-0 transition-opacity mr-1" aria-hidden="true">
                          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12" />
                          </svg>
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </li>
        );
      })
    }
  </ul>
</nav>

<script>
  const STORAGE_KEY = "aprenda-progress";

  function updateSidebarProgress() {
    const completed = new Set<string>(
      JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "[]")
    );
    document.querySelectorAll<HTMLElement>("[data-lesson-href]").forEach((el) => {
      const href = el.getAttribute("data-lesson-href");
      const check = el.querySelector<HTMLElement>(".progress-check");
      if (check) {
        check.style.opacity = href && completed.has(href) ? "1" : "0";
      }
    });
  }

  updateSidebarProgress();
  document.addEventListener("progress-update", updateSidebarProgress);
</script>
