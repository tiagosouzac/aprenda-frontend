---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2);
---

{
  items.length > 0 && (
    <nav class="sticky top-[90px] pt-6 pb-20">
      <div class="mono text-[10.5px] tracking-[0.2em] uppercase text-mute mb-6">
        nesta página
      </div>
      <ul class="ml-[3px] border-l border-line space-y-0.5" role="list" data-toc-list>
        {items.map((h) => (
          <li class="relative" data-toc-item={h.slug}>
            <span
              class="absolute left-[-1px] top-[7px] bottom-[7px] w-[2px] bg-ink opacity-0 transition-opacity"
              data-toc-bar
              aria-hidden="true"
            />
            <a
              href={`#${h.slug}`}
              data-toc-link
              class="block pl-4 py-1 text-[13px] leading-[1.4] text-mute hover:text-ink transition-colors"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  const list = document.querySelector<HTMLElement>("[data-toc-list]");
  if (list) {
    const items = Array.from(
      list.querySelectorAll<HTMLLIElement>("[data-toc-item]"),
    ).map((li) => {
      const slug = li.dataset.tocItem!;
      return {
        target: document.getElementById(slug),
        link: li.querySelector<HTMLAnchorElement>("[data-toc-link]")!,
        bar: li.querySelector<HTMLElement>("[data-toc-bar]")!,
      };
    }).filter((it): it is { target: HTMLElement; link: HTMLAnchorElement; bar: HTMLElement } => it.target !== null);

    let ticking = false;
    const update = () => {
      ticking = false;
      const anchor = window.innerHeight * 0.28;
      let activeIdx = -1;
      items.forEach((item, i) => {
        const top = item.target.getBoundingClientRect().top;
        if (top <= anchor) activeIdx = i;
      });
      if (activeIdx === -1 && items.length > 0) {
        const firstTop = items[0].target.getBoundingClientRect().top;
        if (firstTop < window.innerHeight) activeIdx = 0;
      }
      items.forEach((item, i) => {
        const active = i === activeIdx;
        item.link.classList.toggle("text-ink", active);
        item.link.classList.toggle("text-mute", !active);
        item.link.classList.toggle("font-medium", active);
        item.bar.style.opacity = active ? "1" : "0";
      });
    };

    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", update);
    update();
  }
</script>
